# Note: The current telegram_watcher.py reads credentials from files, not env vars.
# These are for reference if you modify the watcher to use environment variables.
# 注意：目前的 telegram_watcher.py 從檔案讀取憑證，不是環境變數。
# 如果你改 watcher 來使用環境變數，可以參考這些設定。

# Telegram bot token (from @BotFather)
# Telegram bot token（從 @BotFather 取得）
# Default file: ~/.telegram-bot-token (chmod 600)
# 預設檔案：~/.telegram-bot-token（chmod 600）
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram user ID (only this user can interact with the bot)
# 你的 Telegram user ID（只有這個使用者能跟 bot 互動）
# Default file: ~/.telegram-user-id
# 預設檔案：~/.telegram-user-id
TELEGRAM_ALLOWED_USER=123456789

# Data directory for inbox/outbox/transcripts
# inbox/outbox/紀錄的資料目錄
# Default in code: ~/claude-memory
# 程式碼預設：~/claude-memory
# TELEGRAM_DATA_DIR=~/claude-memory

# Whisper model for voice transcription (Apple Silicon only)
# 語音轉錄的 Whisper 模型（僅 Apple Silicon）
# TELEGRAM_WHISPER_MODEL=mlx-community/whisper-small
