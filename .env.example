# Required: Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Required: Your Telegram user ID (only this user can interact with the bot)
TELEGRAM_ALLOWED_USER=123456789

# Optional: Data directory for inbox/outbox/transcripts (default: ./data)
# TELEGRAM_DATA_DIR=/path/to/data

# Optional: Whisper model for voice transcription (default: mlx-community/whisper-small)
# TELEGRAM_WHISPER_MODEL=mlx-community/whisper-small

# Optional: Language for voice transcription (default: auto-detect)
# Examples: en, zh, ja, ko, es, fr, de
# TELEGRAM_WHISPER_LANG=en

# Optional: Shell command to run when a new message arrives
# Example for macOS Terminal nudge:
# TELEGRAM_NUDGE_CMD=osascript -e 'tell application "Terminal" to activate'

# Alternative: Read token/user ID from files instead of env vars
# TELEGRAM_TOKEN_FILE=~/.telegram-bot-token
# TELEGRAM_USER_FILE=~/.telegram-user-id
